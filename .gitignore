# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# --- Виртуальные окружения и локальные зависимости ---
.venv/
venv/
env/
ENV/
.deps/

# --- IDE / ОС ---
.idea/
.vscode/
*.iml
.DS_Store
Thumbs.db
*.swp
*~

# --- Jupyter ---
.ipynb_checkpoints/
*.ipynb_checkpoints

# --- Веса YOLO (скачаются при первом запуске ultralytics) ---
*.pt

# --- Видео и большие данные ---
data/raw_videos/*
!data/raw_videos/.gitkeep
data/test_videos/*
!data/test_videos/.gitkeep

# Обработанные артефакты: позы, датасет, модели, графики
data/processed/*
!data/processed/.gitkeep

# PDF и прочие тяжёлые материалы в data/
data/**/*.pdf

# --- Дипломные документы Word (личные, большие) ---
*.docx
~$*.docx
~$*

# --- Временные и служебные ---
*.log
*.tmp
.cache/

# --- PyTorch / sklearn артефакты вне data/processed ---
*.npz
*.joblib
*_state.pt

